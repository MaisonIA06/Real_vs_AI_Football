# =============================================================================
# Real vs AI — Variables d'environnement pour la production
# =============================================================================
# 1. Copier ce fichier :  cp .env.example .env
# 2. Remplir les valeurs marquées CHANGE_ME
#
# Générer une clé secrète Django :
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=realvsai
POSTGRES_USER=realvsai_user
POSTGRES_PASSWORD=CHANGE_ME_MOT_DE_PASSE_FORT

# --- Django ---
DJANGO_SECRET_KEY=CHANGE_ME_GENERER_CLE_SECRETE
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=204.168.174.92

# --- Redis (nom du service Docker, ne pas changer) ---
REDIS_HOST=redis

# --- CORS / CSRF (avec le protocole http:// puisqu'on est en IP sans SSL) ---
CORS_ALLOWED_ORIGINS=http://204.168.174.92
CSRF_TRUSTED_ORIGINS=http://204.168.174.92

# --- HTTPS (mettre True quand un domaine + SSL sera configuré) ---
USE_HTTPS=False
